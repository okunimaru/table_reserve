<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "TableReserve" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="background-color: #f5efe6; min-height: 100vh;">
    <nav class="navbar navbar-expand-lg" style="background-color: #5c4033;">
      <div class="container">
        <%= link_to "🍺 TableReserve", root_path, class: "navbar-brand text-white fw-bold" %>
        <div class="d-flex gap-2">
          <% if current_user %>
            <% if current_user.role == "admin" %>
              <%= link_to "予約管理", admin_reservations_path, class: "btn btn-outline-light btn-sm" %>
              <%= link_to "メニュー管理", admin_menus_path, class: "btn btn-outline-light btn-sm" %>
            <% else %>
              <%= link_to "予約一覧", reservations_path, class: "btn btn-outline-light btn-sm" %>
              <%= link_to "予約する", new_reservation_path, class: "btn btn-light btn-sm" %>
            <% end %>
            <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete }, class: "btn btn-outline-light btn-sm" %>
          <% else %>
            <%= link_to "ログイン", login_path, class: "btn btn-light btn-sm" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="container mt-4">
       <% if notice %>
        <div class="toast-container position-fixed top-0 start-0 end-0 d-flex justify-content-center p-3" style="z-index: 1100; margin-top: 60px;">
          <div class="toast show align-items-center text-white bg-success border-0" role="alert" id="noticeToast">
            <div class="d-flex">
              <div class="toast-body"><%= notice %></div>
              <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
          </div>
        </div>
      <% end %>
      <% if alert %>
        <div class="toast-container position-fixed top-0 start-0 end-0 d-flex justify-content-center p-3" style="z-index: 1100; margin-top: 60px;">
          <div class="toast show align-items-center text-white bg-danger border-0" role="alert" id="alertToast">
            <div class="d-flex">
              <div class="toast-body"><%= alert %></div>
              <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
          </div>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>