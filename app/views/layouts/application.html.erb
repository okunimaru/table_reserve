<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "TableReserve" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav>
      <%= link_to "ホーム", root_path %>
      <% if current_user %>
        <% if current_user.role == "admin" %>
          <%= link_to "予約管理", admin_reservations_path %>
          <%= link_to "メニュー管理", admin_menus_path %>
        <% else %>
          <%= link_to "予約一覧", reservations_path %>
          <%= link_to "予約する", new_reservation_path %>
        <% end %>
        <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete } %>
      <% else %>
        <%= link_to "ログイン", login_path %>
      <% end %>
    </nav>

    <% if notice %>
      <p><%= notice %></p>
    <% end %>
    <% if alert %>
      <p><%= alert %></p>
    <% end %>

    <%= yield %>
  </body>
</html>