<h1>メニュー管理</h1>

<%= link_to "メニュー追加", new_admin_menu_path %>

<% if @menus.empty? %>
  <p>メニューはありません</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>メニュー名</th>
        <th>説明</th>
        <th>価格</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @menus.each do |menu| %>
        <tr>
          <td><%= menu.name %></td>
          <td><%= menu.description %></td>
          <td><%= menu.price %>円</td>
          <td>
            <%= link_to "編集", edit_admin_menu_path(menu) %>
            <%= link_to "削除", admin_menu_path(menu), data: { turbo_method: :delete, turbo_confirm: "削除しますか？" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>