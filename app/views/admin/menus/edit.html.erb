<h1>メニュー編集</h1>

<%= form_with model: [:admin, @menu] do |f| %>
  <div>
    <%= f.label :name, "メニュー名" %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :description, "説明" %>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :price, "価格" %>
    <%= f.number_field :price, min: 0 %>
  </div>

  <%= f.submit "更新する" %>
<% end %>

<%= link_to "一覧に戻る", admin_menus_path %>