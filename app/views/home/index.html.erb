<div class="text-center py-5">
  <h1 class="display-5 fw-bold mb-3" style="color: #5c4033;">🍺 TableReserve</h1>
  <p class="text-muted fs-5 mb-5">大切な時間を、心地よい席で。</p>

  <% if current_user %>
  <div class="d-flex gap-3 justify-content-center">
    <%= link_to "📅 予約する", new_reservation_path, class: "btn btn-lg text-white px-4", style: "background-color: #5c4033;" %>
    <%= link_to "📋 予約一覧", reservations_path, class: "btn btn-lg px-4", style: "background-color: #d4a574; color: white;" %>
  </div>
  <% else %>
    <div class="bg-white rounded-4 shadow p-5 col-md-5 mx-auto">
      <p class="fs-5 mb-4">ご予約にはログインが必要です</p>
      <%= link_to "ログインする", login_path, class: "btn btn-lg text-white px-5", style: "background-color: #5c4033;" %>
    </div>
  <% end %>

  <div id="carouselDummy" class="carousel slide col-md-8 mx-auto mt-5" data-bs-ride="carousel">
    <div class="carousel-inner rounded-4 shadow">
      <div class="carousel-item active">
        <img src="https://picsum.photos/seed/restaurant1/900/300" class="d-block w-100" style="height: 300px; object-fit: cover;" alt="店内1">
        <div class="carousel-caption">
          <p class="fw-bold">落ち着いた雰囲気の店内</p>
        </div>
      </div>
      <div class="carousel-item">
        <img src="https://picsum.photos/seed/restaurant2/900/300" class="d-block w-100" style="height: 300px; object-fit: cover;" alt="店内2">
        <div class="carousel-caption">
          <p class="fw-bold">こだわりのお料理</p>
        </div>
      </div>
      <div class="carousel-item">
        <img src="https://picsum.photos/seed/restaurant3/900/300" class="d-block w-100" style="height: 300px; object-fit: cover;" alt="店内3">
        <div class="carousel-caption">
          <p class="fw-bold">特別なひとときを</p>
        </div>
      </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselDummy" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselDummy" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>
  </div>

</div>